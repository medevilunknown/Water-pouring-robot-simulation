<?xml version="1.0" ?>
<sdf version="1.8">
  <world name="empty">
    <gravity>0 0 -9.8</gravity>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact"/>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- ══════════════════════════════════════════════════════════
         Ground Plane
         ══════════════════════════════════════════════════════════ -->
    <model name="ground_plane">
      <static>true</static>
      <pose>0 0 -0.05 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>100 100 0.1</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>100 100 0.1</size></box>
          </geometry>
          <material>
            <ambient>0.3 0.3 0.3 1</ambient>
            <diffuse>0.5 0.5 0.5 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ══════════════════════════════════════════════════════════
         Workbench Table
         ══════════════════════════════════════════════════════════ -->
    <model name="workbench_table">
      <static>true</static>
      <pose>-0.55 0 0 0 0 0</pose>
      <link name="table_link">
        <collision name="top_collision">
          <pose>0 0 0.75 0 0 0</pose>
          <geometry>
            <box><size>1.2 0.8 0.05</size></box>
          </geometry>
          <surface>
            <friction>
              <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
            </friction>
          </surface>
        </collision>
        <visual name="top_visual">
          <pose>0 0 0.75 0 0 0</pose>
          <geometry>
            <box><size>1.2 0.8 0.05</size></box>
          </geometry>
          <material>
            <ambient>0.48 0.32 0.20 1</ambient>
            <diffuse>0.58 0.39 0.24 1</diffuse>
            <specular>0.12 0.12 0.12 1</specular>
          </material>
        </visual>

        <collision name="leg_fl_collision">
          <pose>0.53 0.33 0.375 0 0 0</pose>
          <geometry><box><size>0.07 0.07 0.75</size></box></geometry>
        </collision>
        <collision name="leg_fr_collision">
          <pose>0.53 -0.33 0.375 0 0 0</pose>
          <geometry><box><size>0.07 0.07 0.75</size></box></geometry>
        </collision>
        <collision name="leg_rl_collision">
          <pose>-0.53 0.33 0.375 0 0 0</pose>
          <geometry><box><size>0.07 0.07 0.75</size></box></geometry>
        </collision>
        <collision name="leg_rr_collision">
          <pose>-0.53 -0.33 0.375 0 0 0</pose>
          <geometry><box><size>0.07 0.07 0.75</size></box></geometry>
        </collision>

        <visual name="leg_fl_visual">
          <pose>0.53 0.33 0.375 0 0 0</pose>
          <geometry><box><size>0.07 0.07 0.75</size></box></geometry>
          <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.28 0.28 0.28 1</diffuse></material>
        </visual>
        <visual name="leg_fr_visual">
          <pose>0.53 -0.33 0.375 0 0 0</pose>
          <geometry><box><size>0.07 0.07 0.75</size></box></geometry>
          <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.28 0.28 0.28 1</diffuse></material>
        </visual>
        <visual name="leg_rl_visual">
          <pose>-0.53 0.33 0.375 0 0 0</pose>
          <geometry><box><size>0.07 0.07 0.75</size></box></geometry>
          <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.28 0.28 0.28 1</diffuse></material>
        </visual>
        <visual name="leg_rr_visual">
          <pose>-0.53 -0.33 0.375 0 0 0</pose>
          <geometry><box><size>0.07 0.07 0.75</size></box></geometry>
          <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.28 0.28 0.28 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ══════════════════════════════════════════════════════════
         Water Bottle (DYNAMIC — graspable)
         Cylinder r=0.031m, h=0.128m, ~120ml capacity
         Placed on table: table_top=0.775, bottle_center = 0.775 + 0.064 = 0.839
         ══════════════════════════════════════════════════════════ -->
    <model name="water_bottle">
      <pose>-0.27 -0.10 0.839 0 0 0</pose>
      <link name="bottle_link">
        <inertial>
          <mass>0.15</mass>
          <inertia>
            <ixx>3.5e-04</ixx><iyy>3.5e-04</iyy><izz>7.2e-05</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.031</radius>
              <length>0.128</length>
            </cylinder>
          </geometry>
          <surface>
            <friction>
              <ode><mu>1.2</mu><mu2>1.2</mu2></ode>
            </friction>
            <contact>
              <ode>
                <kp>1e6</kp><kd>100</kd>
                <max_vel>0.01</max_vel>
                <min_depth>0.001</min_depth>
              </ode>
            </contact>
          </surface>
        </collision>
        <visual name="bottle_body">
          <geometry>
            <cylinder>
              <radius>0.031</radius>
              <length>0.128</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.15 0.4 0.85 0.7</ambient>
            <diffuse>0.2 0.5 0.9 0.7</diffuse>
            <specular>0.5 0.5 0.5 1</specular>
          </material>
        </visual>
        <!-- Cap visual -->
        <visual name="bottle_cap">
          <pose>0 0 0.069 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.015</radius>
              <length>0.01</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.9 0.9 0.9 1</ambient>
            <diffuse>1.0 1.0 1.0 1</diffuse>
          </material>
        </visual>
        <!-- Water inside (visual only) -->
        <visual name="water_inside">
          <pose>0 0 -0.01 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.028</radius>
              <length>0.09</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.1 0.3 0.9 0.4</ambient>
            <diffuse>0.1 0.4 1.0 0.4</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ══════════════════════════════════════════════════════════
         Target Beaker / Measuring Glass (DYNAMIC)
         Cylinder r=0.03m, h=0.07m, ~150ml capacity
         Placed on table: table_top=0.775, beaker_center = 0.775 + 0.035 = 0.810
         ══════════════════════════════════════════════════════════ -->
    <model name="target_glass">
      <pose>-0.30 0.12 0.810 0 0 0</pose>
      <link name="beaker_link">
        <inertial>
          <mass>0.08</mass>
          <inertia>
            <ixx>1.2e-04</ixx><iyy>1.2e-04</iyy><izz>3.6e-05</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.03</radius>
              <length>0.07</length>
            </cylinder>
          </geometry>
          <surface>
            <friction>
              <ode><mu>0.8</mu><mu2>0.8</mu2></ode>
            </friction>
            <contact>
              <ode>
                <kp>1e6</kp><kd>100</kd>
                <max_vel>0.01</max_vel>
                <min_depth>0.001</min_depth>
              </ode>
            </contact>
          </surface>
        </collision>
        <!-- Glass body (transparent) -->
        <visual name="beaker_body">
          <geometry>
            <cylinder>
              <radius>0.03</radius>
              <length>0.07</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.7 0.85 0.85 0.25</ambient>
            <diffuse>0.8 0.9 0.9 0.25</diffuse>
            <specular>0.6 0.6 0.6 1</specular>
          </material>
        </visual>
        <!-- Measurement markings (visual ring at 100ml height) -->
        <visual name="mark_100ml">
          <pose>0 0 0.012 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.031</radius>
              <length>0.001</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.9 0.1 0.1 1</ambient>
            <diffuse>1.0 0.2 0.2 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ══════════════════════════════════════════════════════════
         External Overhead Camera (fixed, for YOLO detection)
         Positioned 0.6m above table center, looking down at 45°
         ══════════════════════════════════════════════════════════ -->
    <model name="external_camera_mount">
      <static>true</static>
      <pose>-0.10 0.0 1.6 0 0.7854 0</pose>
      <link name="camera_link">
        <visual name="camera_box">
          <geometry>
            <box><size>0.04 0.08 0.03</size></box>
          </geometry>
          <material>
            <ambient>0.1 0.1 0.1 1</ambient>
            <diffuse>0.15 0.15 0.15 1</diffuse>
          </material>
        </visual>
        <sensor name="external_rgbd" type="rgbd_camera">
          <always_on>true</always_on>
          <update_rate>15</update_rate>
          <visualize>true</visualize>
          <topic>/external_camera</topic>
          <camera>
            <horizontal_fov>1.2217</horizontal_fov>
            <image>
              <width>640</width>
              <height>480</height>
              <format>R8G8B8</format>
            </image>
            <clip>
              <near>0.05</near>
              <far>5.0</far>
            </clip>
            <depth_camera>
              <output>depths</output>
              <clip>
                <near>0.05</near>
                <far>5.0</far>
              </clip>
            </depth_camera>
          </camera>
        </sensor>
      </link>
    </model>

  </world>
</sdf>